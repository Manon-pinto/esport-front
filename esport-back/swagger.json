{
  "openapi": "3.0.3",
  "info": {
    "title": "ProLeague Tracker API",
    "version": "1.0.0",
    "description": "API de gestion de tournois e-sport avec système de paris virtuels.\n\n**Comptes de démo :**\n- Admin : `admin@esport.fr` / `password`\n- Parieur : `parieur@esport.fr` / `password`",
    "contact": {
      "name": "My Digital School Bordeaux — CDA"
    }
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Développement local" },
    { "url": "https://monapiexpress.vps114751.serveur-vps.net", "description": "Production VPS" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenu via POST /api/auth/login"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "664f1a2b3c4d5e6f7a8b9c0d" },
          "username": { "type": "string", "example": "parieur" },
          "email": { "type": "string", "format": "email", "example": "parieur@esport.fr" },
          "role": { "type": "string", "enum": ["user", "admin"], "example": "user" },
          "points": { "type": "integer", "example": 1000 }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string", "example": "Team Vitality" },
          "tag": { "type": "string", "example": "VIT" },
          "country": { "type": "string", "example": "FR" },
          "foundedYear": { "type": "integer", "example": 2013 },
          "isActive": { "type": "boolean", "example": true }
        }
      },
      "Match": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "tournamentId": { "type": "string" },
          "team1Id": { "type": "string" },
          "team2Id": { "type": "string" },
          "scheduledAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["scheduled", "live", "finished", "cancelled"] },
          "scoreTeam1": { "type": "integer" },
          "scoreTeam2": { "type": "integer" },
          "winnerId": { "type": "string" },
          "bestOf": { "type": "integer", "example": 3 }
        }
      },
      "Tournament": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string", "example": "ESL Pro League S21" },
          "game": { "type": "string", "example": "Counter-Strike 2" },
          "prizePool": { "type": "integer", "example": 750000 },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "location": { "type": "string", "example": "Cologne, Germany" },
          "status": { "type": "string", "enum": ["upcoming", "ongoing", "finished"] }
        }
      },
      "Player": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "nickname": { "type": "string", "example": "ZywOo" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "nationality": { "type": "string", "example": "FR" },
          "age": { "type": "integer" },
          "role": { "type": "string", "example": "AWPer" },
          "teamId": { "type": "string" }
        }
      },
      "Coach": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string", "example": "YNk" },
          "nationality": { "type": "string" },
          "teamId": { "type": "string" }
        }
      },
      "Bet": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "matchId": { "type": "string" },
          "teamId": { "type": "string" },
          "amount": { "type": "integer", "example": 100 },
          "odds": { "type": "number", "example": 1.9 },
          "potentialGain": { "type": "integer", "example": 190 },
          "status": { "type": "string", "enum": ["pending", "won", "lost", "refunded"] }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Inscription",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string", "example": "nouveauJoueur" },
                  "email": { "type": "string", "format": "email", "example": "joueur@esport.fr" },
                  "password": { "type": "string", "minLength": 6, "example": "monMotDePasse" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Compte créé — retourne le token JWT",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": { "description": "Champs manquants ou email déjà utilisé" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Connexion",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "parieur@esport.fr" },
                  "password": { "type": "string", "example": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connexion réussie",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": { "description": "Champs manquants" },
          "401": { "description": "Mot de passe incorrect" },
          "404": { "description": "Email inconnu" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Profil de l'utilisateur connecté",
        "tags": ["Auth"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Profil utilisateur",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "user": { "$ref": "#/components/schemas/User" } }
                }
              }
            }
          },
          "401": { "description": "Token manquant ou invalide" }
        }
      }
    },
    "/api/auth/leaderboard": {
      "get": {
        "summary": "Classement des parieurs par points",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Liste triée par points décroissants (sans mots de passe)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/User" }
                }
              }
            }
          }
        }
      }
    },
    "/api/pari": {
      "get": {
        "summary": "Mes paris",
        "tags": ["Paris"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Liste des paris de l'utilisateur connecté",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Bet" } }
              }
            }
          },
          "401": { "description": "Non authentifié" }
        }
      },
      "post": {
        "summary": "Placer un pari",
        "tags": ["Paris"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["matchId", "teamId", "amount"],
                "properties": {
                  "matchId": { "type": "string" },
                  "teamId": { "type": "string" },
                  "amount": { "type": "integer", "minimum": 10, "maximum": 1000, "example": 100 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pari placé — cote fixe 1.9",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bet" }
              }
            }
          },
          "400": { "description": "Validation échouée (montant hors limites, pari déjà existant, points insuffisants, équipe non participante)" },
          "401": { "description": "Non authentifié" },
          "404": { "description": "Match introuvable" }
        }
      }
    },
    "/api/pari/{id}": {
      "delete": {
        "summary": "Annuler un pari",
        "tags": ["Paris"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Pari annulé et points remboursés" },
          "400": { "description": "Match non annulable (statut différent de scheduled)" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Pari d'un autre utilisateur" },
          "404": { "description": "Pari introuvable" }
        }
      }
    },
    "/api/teams": {
      "get": {
        "summary": "Liste des équipes",
        "tags": ["Équipes"],
        "responses": {
          "200": {
            "description": "Toutes les équipes",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Team" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Créer une équipe",
        "tags": ["Équipes"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "tag"],
                "properties": {
                  "name": { "type": "string" },
                  "tag": { "type": "string" },
                  "country": { "type": "string" },
                  "foundedYear": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Équipe créée" },
          "400": { "description": "Champs manquants ou nom dupliqué" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" }
        }
      }
    },
    "/api/teams/{id}": {
      "get": {
        "summary": "Détail d'une équipe",
        "tags": ["Équipes"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Équipe trouvée" },
          "404": { "description": "Équipe introuvable" }
        }
      },
      "put": {
        "summary": "Modifier une équipe",
        "tags": ["Équipes"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Team" }
            }
          }
        },
        "responses": {
          "200": { "description": "Équipe modifiée" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Équipe introuvable" }
        }
      },
      "delete": {
        "summary": "Supprimer une équipe",
        "tags": ["Équipes"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Équipe supprimée" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Équipe introuvable" }
        }
      }
    },
    "/api/matches": {
      "get": {
        "summary": "Liste des matchs",
        "tags": ["Matchs"],
        "responses": {
          "200": {
            "description": "Tous les matchs",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Match" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Créer un match",
        "tags": ["Matchs"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tournamentId", "team1Id", "team2Id", "scheduledAt"],
                "properties": {
                  "tournamentId": { "type": "string" },
                  "team1Id": { "type": "string" },
                  "team2Id": { "type": "string" },
                  "scheduledAt": { "type": "string", "format": "date-time" },
                  "bestOf": { "type": "integer", "default": 3 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Match créé" },
          "400": { "description": "Champs manquants" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" }
        }
      }
    },
    "/api/matches/{id}": {
      "get": {
        "summary": "Détail d'un match",
        "tags": ["Matchs"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Match trouvé" },
          "404": { "description": "Match introuvable" }
        }
      },
      "put": {
        "summary": "Modifier un match (résout les paris si finished)",
        "tags": ["Matchs"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["scheduled", "live", "finished", "cancelled"] },
                  "scoreTeam1": { "type": "integer" },
                  "scoreTeam2": { "type": "integer" },
                  "winnerId": { "type": "string", "description": "Requis si status = finished. Déclenche la résolution automatique des paris (cote 1.9)." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Match modifié. Si status=finished, les paris gagnants sont crédités (×1.9) et les perdants sont débités." },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Match introuvable" }
        }
      },
      "delete": {
        "summary": "Supprimer un match",
        "tags": ["Matchs"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Match supprimé" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Match introuvable" }
        }
      }
    },
    "/api/tournois": {
      "get": {
        "summary": "Liste des tournois",
        "tags": ["Tournois"],
        "responses": {
          "200": {
            "description": "Tous les tournois",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Tournament" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Créer un tournoi",
        "tags": ["Tournois"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "game"],
                "properties": {
                  "name": { "type": "string" },
                  "game": { "type": "string" },
                  "prizePool": { "type": "integer" },
                  "startDate": { "type": "string", "format": "date-time" },
                  "endDate": { "type": "string", "format": "date-time" },
                  "location": { "type": "string" },
                  "status": { "type": "string", "enum": ["upcoming", "ongoing", "finished"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tournoi créé" },
          "400": { "description": "Champs manquants" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" }
        }
      }
    },
    "/api/tournois/{id}": {
      "get": {
        "summary": "Détail d'un tournoi",
        "tags": ["Tournois"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Tournoi trouvé" },
          "404": { "description": "Tournoi introuvable" }
        }
      },
      "put": {
        "summary": "Modifier un tournoi",
        "tags": ["Tournois"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Tournament" } }
          }
        },
        "responses": {
          "200": { "description": "Tournoi modifié" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Tournoi introuvable" }
        }
      },
      "delete": {
        "summary": "Supprimer un tournoi",
        "tags": ["Tournois"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Tournoi supprimé" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Tournoi introuvable" }
        }
      }
    },
    "/api/tournois/{id}/matches": {
      "get": {
        "summary": "Matchs d'un tournoi",
        "tags": ["Tournois"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Liste des matchs du tournoi" },
          "404": { "description": "Tournoi introuvable" }
        }
      }
    },
    "/api/players": {
      "get": {
        "summary": "Liste des joueurs",
        "tags": ["Joueurs"],
        "responses": {
          "200": {
            "description": "Tous les joueurs",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Player" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Créer un joueur",
        "tags": ["Joueurs"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nickname"],
                "properties": {
                  "nickname": { "type": "string" },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "nationality": { "type": "string" },
                  "age": { "type": "integer" },
                  "role": { "type": "string" },
                  "teamId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Joueur créé" },
          "400": { "description": "Champs manquants ou nickname dupliqué" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" }
        }
      }
    },
    "/api/players/{id}": {
      "get": {
        "summary": "Détail d'un joueur",
        "tags": ["Joueurs"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Joueur trouvé" },
          "404": { "description": "Joueur introuvable" }
        }
      },
      "put": {
        "summary": "Modifier un joueur",
        "tags": ["Joueurs"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Player" } }
          }
        },
        "responses": {
          "200": { "description": "Joueur modifié" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Joueur introuvable" }
        }
      },
      "delete": {
        "summary": "Supprimer un joueur",
        "tags": ["Joueurs"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Joueur supprimé" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" },
          "404": { "description": "Joueur introuvable" }
        }
      }
    },
    "/api/coach": {
      "get": {
        "summary": "Liste des coachs",
        "tags": ["Coachs"],
        "responses": {
          "200": {
            "description": "Tous les coachs",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Coach" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Créer un coach",
        "tags": ["Coachs"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "nationality": { "type": "string" },
                  "teamId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Coach créé" },
          "400": { "description": "Champs manquants ou nom dupliqué" },
          "401": { "description": "Non authentifié" },
          "403": { "description": "Rôle admin requis" }
        }
      }
    },
    "/api/coach/{id}": {
      "get": {
        "summary": "Détail d'un coach",
